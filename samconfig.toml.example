# samconfig.toml.example — Copy to samconfig.toml and fill in your real values.
# samconfig.toml is in .gitignore — NEVER commit with real values.

version = 0.1

[default.global.parameters]
stack_name = "finance-lambda"
region     = "us-east-1"   # change to your preferred region

[default.build.parameters]
cached   = true
parallel = true

[default.deploy.parameters]
capabilities      = "CAPABILITY_IAM"
confirm_changeset = true
resolve_s3        = true
s3_prefix         = "finance-lambda"

# Fill in your real values (no spaces around =)
parameter_overrides = [
  "FinanceSheetId=YOUR_SHEET_ID_HERE",
  "FinanceSaKeyJson={\"type\":\"service_account\",\"project_id\":\"...\"}",
  "TelegramBotToken=YOUR_BOT_TOKEN_HERE",
  "TelegramChatId=YOUR_CHAT_ID_HERE",
  "BudgetPareja=3000",
  "BudgetMantys=500",
  "Environment=prod"
]
