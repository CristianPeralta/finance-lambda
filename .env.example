# .env.example — Variables de entorno para Lambda.
# Copia a .env y completa con valores reales.
# .env está en .gitignore — NUNCA commitear con valores reales.
#
# En producción estas variables se pasan como Parameters en samconfig.toml,
# no como .env. Este archivo sirve para desarrollo local / testing.

# ─── Google Sheets ────────────────────────────────────────────────────────────
# ID visible en la URL del Sheet:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
FINANCE_SHEET_ID=your_google_sheet_id_here

# Contenido completo del JSON del service account, en una sola línea.
# Obtener desde Google Cloud Console → IAM → Service Accounts → Keys → Add Key → JSON
# Minificar con: cat finance-sa.json | python3 -m json.tool --no-indent | tr -d '\n'
FINANCE_SA_KEY_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"finance@project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Token del bot creado con @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Chat ID donde el bot manda notificaciones y alertas.
# Para obtenerlo: manda un mensaje al bot y llama:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# ─── Presupuestos (alertas diarias) ──────────────────────────────────────────
# Monto mensual en soles peruanos (S/)
BUDGET_PAREJA=3000
BUDGET_MANTYS=500
