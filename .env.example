# .env.example — Lambda environment variables.
# Copy to .env and fill in your real values.
# .env is in .gitignore — NEVER commit with real values.
#
# In production these are passed as SAM Parameters in samconfig.toml, not as .env.
# This file is for local development and testing only.

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Sheet ID from the URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
FINANCE_SHEET_ID=your_google_sheet_id_here

# Full service account JSON minified to a single line.
# Get it from Google Cloud Console -> IAM -> Service Accounts -> Keys -> Add Key -> JSON
# Minify with: cat finance-sa.json | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin)))"
FINANCE_SA_KEY_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"finance@project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Chat ID where the bot sends notifications and alerts.
# To get it: send any message to the bot, then call:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# ─── Budgets (daily alerts) ───────────────────────────────────────────────────
# Monthly budget in Peruvian soles (S/)
BUDGET_PAREJA=3000
BUDGET_MANTYS=500

# ─── Personal users ───────────────────────────────────────────────────────────
# Lowercase names matching Google Sheet tab names (tabs must be named User1/User2 capitalized)
FINANCE_USER1=user1
FINANCE_USER2=user2
